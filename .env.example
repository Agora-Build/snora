# MAX_CONCURRENT_SESSIONS=4
# GPU_DEVICE_ID=0
# PORT=8080
# MAX_SESSION_DURATION_HOURS=12
# IDLE_TIMEOUT_MINUTES=30
# CLIENT_DISCONNECT_GRACE_MINUTES=5
# LOG_LEVEL=info
